{% load static %}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link rel="shortcut icon" href="{% static 'img/fav.png' %}">
    <meta charset="UTF-8">
    <title>{% block title %}Travel Buddy{% endblock %}</title>

    <link href="https://fonts.googleapis.com/css?family=Poppins:100,200,300,400,500,600,700" rel="stylesheet">
    <link rel="stylesheet" href="{% static 'css/linearicons.css' %}">
    <link rel="stylesheet" href="{% static 'css/font-awesome.min.css' %}">
    <link rel="stylesheet" href="{% static 'css/bootstrap.css' %}">
    <link rel="stylesheet" href="{% static 'css/magnific-popup.css' %}">
    <link rel="stylesheet" href="{% static 'css/animate.min.css' %}">
    <link rel="stylesheet" href="{% static 'css/owl.carousel.css' %}">
    <link rel="stylesheet" href="{% static 'css/main.css' %}">

    {% block extra_css %}{% endblock %}
    <style>
        /* Common alert styling used across site */
        .site-alert {
            border-radius: 10px;
            padding: 16px 20px;
            margin-bottom: 20px;
            font-weight: 500;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.12);
        }
        .site-alert-success { background: #d4edda; color: #155724; border-left: 5px solid #28a745; }
        .site-alert-danger { background: #f8d7da; color: #721c24; border-left: 5px solid #dc3545; }
        .site-alert-warning { background: #fff3cd; color: #856404; border-left: 5px solid #ffc107; }
        .site-alert-info { background: #d1ecf1; color: #0c5460; border-left: 5px solid #17a2b8; }
        .site-alert .btn-close { opacity: 0.85; }
        .site-alert .btn-close:hover { opacity: 1; }
        .navbar-brand .brand-icon { font-size: 28px; }
    </style>
</head>

<body>
    <header class="default-header">
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container">
                <a class="navbar-brand" href="{% url 'index' %}">
                    <div class="d-flex align-items-center">
                        <i class="fa fa-suitcase text-white mr-2 brand-icon"></i>
                        <span class="text-white" style="font-size:24px;font-weight:700;letter-spacing:1px;">Travel Buddy</span>
                    </div>
                </a>
                <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent"
                    aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="text-white lnr lnr-menu"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-between align-items-center" id="navbarSupportedContent">
                    <ul class="navbar-nav">
                        <li class="nav-item"><a class="nav-link" href="{% url 'index' %}">Home</a></li>
                        <li class="nav-item"><a class="nav-link" href="{% url 'browse_trips' %}">Browse Trips</a></li>
                        <li class="nav-item"><a class="nav-link" href="{% url 'login' %}">Login</a></li>
                        <li class="nav-item"><a class="nav-link" href="{% url 'register' %}">Register</a></li>
                    </ul>
                    {% block nav_right %}{% endblock %}
                </div>
            </div>
        </nav>
    </header>

    <main>
        <div class="container mt-4">
            {% if messages %}
                {% for message in messages %}
                    <div class="site-alert site-alert-{{ message.tags|default:'info' }} alert-dismissible fade show" role="alert">
                        <div class="d-flex align-items-center">
                            <i class="fa {% if message.tags == 'success' %}fa-check-circle{% elif message.tags == 'danger' %}fa-exclamation-circle{% elif message.tags == 'warning' %}fa-exclamation-triangle{% else %}fa-info-circle{% endif %} me-3"></i>
                            <div class="flex-grow-1">{{ message }}</div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    </div>
                {% endfor %}
            {% endif %}

            {% block content %}{% endblock %}
        </div>
    </main>

    <footer class="footer-area section-gap mt-5">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 text-center">
                    <p class="mb-0">&copy; {{ now|date:"Y" }} Travel Buddy. All rights reserved.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="{% static 'js/vendor/jquery-2.2.4.min.js' %}"></script>
    <script src="{% static 'js/popper.min.js' %}"></script>
    <script src="{% static 'js/bootstrap.min.js' %}"></script>
    <script src="{% static 'js/owl.carousel.min.js' %}"></script>
    <script src="{% static 'js/main.js' %}"></script>
    {% block extra_js %}{% endblock %}
</body>

</html>
